CDateTimeAddMonths	SELECT ("a0"."CreatedDate" + INTERVAL '6 month') AS "Plus6M" FROM "products" "a0"	
CDateTimeAddYears	SELECT ("a0"."CreatedDate" + INTERVAL '1 year') AS "Plus1Y" FROM "products" "a0"	
CDateTimeDiffDays	SELECT EXTRACT(DAY FROM (:p0 - "a0"."CreatedDate")) AS "Diff" FROM "products" "a0"	:p0=dateTime "2025-01-01 00:00:00"
CDateTimeDiffMonths	SELECT (EXTRACT(YEAR FROM :p0) - EXTRACT(YEAR FROM "a0"."CreatedDate")) * 12 + (EXTRACT(MONTH FROM :p0) - EXTRACT(MONTH FROM "a0"."CreatedDate")) AS "Diff" FROM "products" "a0"	:p0=dateTime "2025-01-01 00:00:00"
CDateTimeDiffYears	SELECT (EXTRACT(YEAR FROM :p0) - EXTRACT(YEAR FROM "a0"."CreatedDate")) AS "Diff" FROM "products" "a0"	:p0=dateTime "2025-01-01 00:00:00"
