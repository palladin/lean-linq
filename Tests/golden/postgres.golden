CDateTimeYear	SELECT EXTRACT(YEAR FROM "a0"."CreatedDate") AS "Year" FROM "products" "a0"	
CDateTimeMonth	SELECT EXTRACT(MONTH FROM "a0"."CreatedDate") AS "Month" FROM "products" "a0"	
CDateTimeDay	SELECT EXTRACT(DAY FROM "a0"."CreatedDate") AS "Day" FROM "products" "a0"	
